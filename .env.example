# ============================================================
# 编钟调音系统 - 环境变量模板
# 复制为 .env 并修改
# ============================================================

# ---------- Database (TimescaleDB)
DB_PORT=5432
DB_PASSWORD=bianzhong_secure_pw_CHANGEME_2024

# ---------- Go Backend
SERVER_PORT=8080
PPROF_PORT=6060

# ---------- MQTT Broker
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ---------- Prometheus
PROM_PORT=9090

# ---------- Grafana
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin123

# ---------- Nginx (optional profile)
NGINX_PORT=80

# ---------- Bell Simulator (optional profile: simulator)
SIM_BELL_ID=bell-sim-01
SIM_BELL_NAME=仿真编钟-Sim01
SIM_DIAMETER=40.0
SIM_HEIGHT=80.0
SIM_THICKNESS=15.0

# 音高目标 (两者任一即可；TARGET_NOTE 覆盖 TARGET_FREQ
SIM_TARGET_NOTE=E4
SIM_TARGET_FREQ=329.63
SIM_TOLERANCE=10
SIM_INITIAL_OFFSET=45
SIM_MEASURE_INTERVAL=5
SIM_NOISE=2
SIM_GRIND_ENABLED=1
SIM_GRIND_INTERVAL=3
# 磨锉位置 (角度逗号分隔)
SIM_GRIND_POSITIONS=0,45,90,135,180,225,270,315
# 磨锉高度层 (归一化0-1)
SIM_GRIND_HEIGHTS=0.3,0.5,0.7
SIM_GRIND_DEPTH=0.12
SIM_AUTO_TUNE=1
SIM_SESSION_SECONDS=0
SIM_VERBOSE=0
